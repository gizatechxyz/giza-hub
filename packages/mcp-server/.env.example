# Required — Partner API credentials
GIZA_API_KEY=your-partner-api-key
GIZA_PARTNER_NAME=your-partner-name
GIZA_CHAIN_ID=8453

# Optional — Defaults to Giza production URL
# GIZA_API_URL=https://partners-backend-1038109371738.europe-west1.run.app

# Optional — Transport mode (stdio or http)
# TRANSPORT=stdio

# Optional — HTTP port (only used when TRANSPORT=http)
# PORT=3000
