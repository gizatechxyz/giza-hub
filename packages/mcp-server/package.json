{
  "name": "@gizatech/mcp-server",
  "version": "0.0.2",
  "description": "MCP server for Giza DeFi yield optimization - library-first with CLI convenience",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "giza-mcp": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "test:e2e": "bun run build && jest --config jest.e2e.config.js",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "giza",
    "mcp",
    "model-context-protocol",
    "defi",
    "yield",
    "optimization",
    "llm"
  ],
  "author": "Giza",
  "license": "MIT",
  "dependencies": {
    "@gizatech/agent-sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "1.27.0",
    "zod": "3.24.2"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/node": "22.13.5",
    "jest": "29.7.0",
    "ts-jest": "29.4.1",
    "tsup": "8.4.0",
    "tsx": "4.19.3",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=18"
  }
}
