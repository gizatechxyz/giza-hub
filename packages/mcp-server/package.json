{
  "name": "@gizatech/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:login && next build",
    "dev": "next dev",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:unit": "bun test src/__tests__/unit",
    "test:integration": "bun test src/__tests__/integration",
    "build:login": "bun run build:login:css && bun run build:login:js",
    "build:login:css": "bunx @tailwindcss/cli -i src/auth/login.css -o public/login.css --minify",
    "build:login:js": "bun build src/auth/login-entry.tsx --outdir public --minify --target browser --define import.meta.env.MODE=\\\"production\\\" --define import.meta.env={}"
  },
  "dependencies": {
    "@gizatech/agent-sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@privy-io/node": "0.8.0",
    "@privy-io/react-auth": "^3.16.0",
    "jose": "6.1.3",
    "mcp-handler": "1.0.7",
    "next": "16.1.6",
    "redis": "^4.7.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.0",
    "tailwindcss": "4.2.1",
    "typescript": "^5.3.3"
  }
}
