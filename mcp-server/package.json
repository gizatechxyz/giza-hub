{
  "name": "@gizatech/mcp-server",
  "version": "0.0.1",
  "description": "MCP server for Giza Agent SDK — conversational DeFi agent interface",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "giza-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@gizatech/agent-sdk": "workspace:*",
    "@modelcontextprotocol/sdk": "1.27.0",
    "siwe": "2.3.2",
    "viem": "2.23.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.13.4",
    "tsup": "8.3.6",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "3.0.5"
  },
  "engines": {
    "node": ">=22"
  }
}
