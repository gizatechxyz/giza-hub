{
  "name": "@giza/agent-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Giza Agents - enables partners to integrate Giza agents into their applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "example": "tsx examples/create-account.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "giza",
    "defi",
    "yield",
    "optimization",
    "zerodev",
    "smart-account",
    "sdk"
  ],
  "author": "Giza",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.5",
    "dotenv": "^16.3.1",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}

